page {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  overflow: hidden;
  color: #25295a;
  background: linear-gradient(145deg, #eef0ff 0%, #fff0f5 48%, #e9ecff 100%);
}

.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  color: #25295a;
  background: linear-gradient(145deg, #eef0ff 0%, #fff0f5 48%, #e9ecff 100%);
}

.home-page {
  width: 100vw;
  height: 100vh;
  padding: calc(128rpx + env(safe-area-inset-top)) 0 calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(145deg, #eef0ff 0%, #fff0f5 48%, #e9ecff 100%);
}

.home-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.home-title {
  color: #25295a;
  font-size: 92rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.home-subtitle {
  color: #5f6178;
  font-size: 34rpx;
  font-weight: 400;
  letter-spacing: 0.3em;
}

.home-logo-wrap {
  width: 460rpx;
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 0;
}

.home-logo {
  width: 460rpx;
  height: auto;
  display: block;
}

.home-desc {
  margin-top: 26rpx;
  color: #5f6178;
  font-size: 30rpx;
  font-weight: 400;
  text-align: center;
  white-space: nowrap;
}

.home-actions {
  width: 100%;
  margin-top: 24rpx;
  padding: 0 52rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.home-card {
  width: 100%;
  height: 196rpx;
  margin: 0;
  padding: 0 34rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 30rpx;
  border-radius: 44rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 20rpx 46rpx rgba(80, 80, 120, 0.12);
  backdrop-filter: blur(20px);
  overflow: hidden;
}

.home-card-icon {
  position: relative;
  flex: none;
  width: 136rpx;
  height: 136rpx;
  border-radius: 34rpx;
  overflow: hidden;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.before-icon {
  background: linear-gradient(145deg, #fac3ce 0%, #d38aa7 100%);
}

.after-icon {
  background: linear-gradient(145deg, #d5d5ff 0%, #929bd5 100%);
}

.home-card-copy {
  flex: 1;
  min-width: 0;
  width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  text-align: left;
}

.home-card-title {
  color: #25295a;
  font-size: 38rpx;
  font-weight: 700;
  white-space: nowrap;
}

.home-card-text {
  color: #6b6e86;
  font-size: 24rpx;
  font-weight: 400;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.home-card-arrow {
  flex: none;
  width: 34rpx;
  color: rgba(37, 41, 90, 0.62);
  font-size: 78rpx;
  font-weight: 300;
  line-height: 1;
}

.home-icon-corner {
  position: absolute;
  width: 26rpx;
  height: 26rpx;
  border-color: rgba(255, 255, 255, 0.95);
  border-style: solid;
}

.corner-tl {
  left: 34rpx;
  top: 32rpx;
  border-width: 6rpx 0 0 6rpx;
  border-radius: 7rpx 0 0 0;
}

.corner-tr {
  right: 34rpx;
  top: 32rpx;
  border-width: 6rpx 6rpx 0 0;
  border-radius: 0 7rpx 0 0;
}

.corner-bl {
  left: 34rpx;
  bottom: 32rpx;
  border-width: 0 0 6rpx 6rpx;
  border-radius: 0 0 0 7rpx;
}

.corner-br {
  right: 34rpx;
  bottom: 32rpx;
  border-width: 0 6rpx 6rpx 0;
  border-radius: 0 0 7rpx 0;
}

.home-icon-mountain {
  position: absolute;
  left: 45rpx;
  bottom: 40rpx;
  width: 0;
  height: 0;
  border-left: 28rpx solid transparent;
  border-right: 28rpx solid transparent;
  border-bottom: 40rpx solid #ffffff;
}

.home-icon-photo {
  position: absolute;
  box-sizing: border-box;
  border: 6rpx solid rgba(255, 255, 255, 0.96);
  border-radius: 10rpx;
}

.photo-back {
  right: 31rpx;
  top: 31rpx;
  width: 58rpx;
  height: 62rpx;
  opacity: 0.88;
}

.photo-front {
  left: 34rpx;
  bottom: 34rpx;
  width: 66rpx;
  height: 68rpx;
}

.home-icon-dot {
  position: absolute;
  left: 11rpx;
  top: 11rpx;
  width: 11rpx;
  height: 11rpx;
  border-radius: 50%;
  background: #ffffff;
}

.home-icon-small-mountain {
  position: absolute;
  left: 10rpx;
  bottom: 8rpx;
  width: 0;
  height: 0;
  border-left: 15rpx solid transparent;
  border-right: 15rpx solid transparent;
  border-bottom: 22rpx solid #ffffff;
}

.home-privacy {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #6b6e86;
  font-size: 19rpx;
  font-weight: 400;
  text-align: center;
}

.home-lock-icon {
  position: relative;
  width: 22rpx;
  height: 24rpx;
  flex: none;
}

.home-lock-shackle {
  position: absolute;
  left: 5rpx;
  top: 0;
  width: 12rpx;
  height: 12rpx;
  box-sizing: border-box;
  border: 3rpx solid #6b6e86;
  border-bottom: none;
  border-radius: 12rpx 12rpx 0 0;
}

.home-lock-body {
  position: absolute;
  left: 2rpx;
  bottom: 0;
  width: 18rpx;
  height: 15rpx;
  box-sizing: border-box;
  border: 3rpx solid #6b6e86;
  border-radius: 4rpx;
}

.home-privacy-text {
  white-space: nowrap;
}

.import-loading-mask {
  position: fixed;
  left: 0;
  top: 0;
  z-index: 120;
  width: 100vw;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(238, 240, 255, 0.62);
  backdrop-filter: blur(16px);
}

.import-loading-box {
  width: 240rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  color: #25295a;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  background: rgba(255, 255, 255, 0.76);
  box-shadow: 0 18rpx 42rpx rgba(80, 80, 120, 0.14);
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

.top-panel {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 20;
  width: 100%;
  height: calc(116rpx + env(safe-area-inset-top));
  padding: calc(22rpx + env(safe-area-inset-top)) 34rpx 12rpx;
  box-sizing: border-box;
  background: linear-gradient(145deg, rgba(238, 240, 255, 0.98) 0%, rgba(255, 240, 245, 0.96) 54%, rgba(233, 236, 255, 0.98) 100%);
}

.angle-bar {
  position: relative;
  height: 72rpx;
  padding: 6rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
  box-shadow: 0 16rpx 38rpx rgba(80, 80, 120, 0.12);
  backdrop-filter: blur(20px);
}

.angle-indicator {
  position: absolute;
  top: 6rpx;
  bottom: 6rpx;
  z-index: 0;
  width: 20%;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #fac3ce 0%, #d7d7ff 100%);
  box-shadow: 0 8rpx 18rpx rgba(112, 104, 166, 0.16);
  transition: left 220ms ease;
}

.angle-button {
  position: relative;
  z-index: 1;
  flex: 1;
  height: 60rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: rgba(37, 41, 90, 0.58);
  background: transparent;
  font-size: 25rpx;
  font-weight: 600;
  box-shadow: none;
}

.angle-button::after,
.action-button::after,
.mode-button::after,
.done-button::after {
  border: none;
}

.angle-button-active {
  color: #25295a;
  background: transparent;
}

.camera-wrap {
  position: fixed;
  top: calc(130rpx + env(safe-area-inset-top));
  left: 34rpx;
  right: 34rpx;
  bottom: calc(188rpx + env(safe-area-inset-bottom));
  z-index: 1;
  box-sizing: border-box;
  border: 8rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 42rpx;
  overflow: hidden;
  background: #000000;
  box-shadow: 0 22rpx 54rpx rgba(80, 80, 120, 0.2);
}

.camera {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 34rpx;
}

.before-overlay {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 3;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.guide-layer {
  position: absolute;
  top: 0;
  left: 0;
  z-index: 5;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.guide-image {
  pointer-events: none;
}

.face-outline-overlay,
.silhouette-overlay {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 8;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.face-outline-loading {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 42;
  width: 248rpx;
  height: 62rpx;
  line-height: 62rpx;
  border-radius: 999rpx;
  color: #25295a;
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 12rpx 28rpx rgba(37, 41, 90, 0.16);
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
  transform: translate(-50%, -50%);
}

.overlay-slider {
  position: absolute;
  right: 0;
  top: 50%;
  z-index: 40;
  width: 154rpx;
  height: 480rpx;
  padding: 0;
  box-sizing: border-box;
  transform: translateY(-50%);
  background: transparent;
  overflow: visible;
}

.overlay-slider-text {
  position: absolute;
  left: 70rpx;
  top: 0;
  width: 84rpx;
  height: 32rpx;
  line-height: 32rpx;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 600;
  text-align: center;
  text-shadow:
    -1rpx 0 rgba(82, 72, 150, 0.9),
    1rpx 0 rgba(82, 72, 150, 0.9),
    0 -1rpx rgba(82, 72, 150, 0.9),
    0 1rpx rgba(82, 72, 150, 0.9),
    0 2rpx 8rpx rgba(37, 41, 90, 0.28);
}

.overlay-slider-track {
  position: absolute;
  left: 0;
  top: 72rpx;
  width: 154rpx;
  height: 360rpx;
  margin: 0;
  overflow: visible;
}

.overlay-slider-base {
  position: absolute;
  top: 7%;
  bottom: 7%;
  left: 122rpx;
  width: 5rpx;
  height: auto;
  border-radius: 999rpx;
  background: rgba(37, 41, 90, 0.24);
  transform: translateX(-50%);
}

.opacity-node {
  position: absolute;
  left: 0;
  width: 154rpx;
  height: 48rpx;
  transform: translateY(-50%);
}

.opacity-dot {
  position: absolute;
  left: 110rpx;
  top: 50%;
  width: 24rpx;
  height: 24rpx;
  margin: 0;
  box-sizing: border-box;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.86);
  background: rgba(37, 41, 90, 0.5);
  box-shadow: 0 4rpx 12rpx rgba(37, 41, 90, 0.22);
  transform: translateY(-50%);
}

.opacity-label {
  position: absolute;
  left: 0;
  top: 50%;
  width: 86rpx;
  height: 28rpx;
  line-height: 28rpx;
  margin-top: 0;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  text-align: right;
  transform: translateY(-50%);
  text-shadow:
    -1rpx 0 rgba(82, 72, 150, 0.9),
    1rpx 0 rgba(82, 72, 150, 0.9),
    0 -1rpx rgba(82, 72, 150, 0.9),
    0 1rpx rgba(82, 72, 150, 0.9),
    0 2rpx 8rpx rgba(37, 41, 90, 0.28);
}

.opacity-active-dot {
  position: absolute;
  left: 110rpx;
  width: 24rpx;
  height: 24rpx;
  box-sizing: border-box;
  border: 4rpx solid #25295a;
  border-radius: 50%;
  background: #fac3ce;
  box-shadow: 0 6rpx 16rpx rgba(37, 41, 90, 0.32);
  transform: translateY(-50%);
}

.opacity-node-active .opacity-dot {
  width: 24rpx;
  height: 24rpx;
  margin-top: 0;
  border-color: #25295a;
  background: #fac3ce;
  box-shadow: 0 6rpx 16rpx rgba(37, 41, 90, 0.32);
}

.opacity-node-active .opacity-label {
  color: #ffffff;
}

.shutter-wrap {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 24rpx;
  z-index: 30;
  height: 140rpx;
  overflow: visible;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 0;
}

.shutter-button {
  width: 128rpx;
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 8rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.58);
  box-shadow: 0 12rpx 28rpx rgba(37, 41, 90, 0.28);
}

.shutter-inner {
  width: 94rpx;
  height: 94rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #4b518c 0%, #25295a 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
}

.camera-flip-button {
  position: absolute;
  right: 26rpx;
  bottom: 38rpx;
  z-index: 36;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: 0 8rpx 22rpx rgba(37, 41, 90, 0.18);
}

.camera-flip-icon {
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  color: #25295a;
  font-size: 38rpx;
  font-weight: 700;
  text-align: center;
}

.face-outline-toggle-group {
  position: absolute;
  left: 26rpx;
  bottom: 40rpx;
  z-index: 36;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.face-outline-toggle {
  width: 156rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: rgba(37, 41, 90, 0.74);
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: 0 8rpx 22rpx rgba(37, 41, 90, 0.16);
  transition: color 180ms ease, border-color 180ms ease, background 180ms ease;
}

.face-outline-toggle-active {
  color: #ffffff;
  border-color: rgba(255, 255, 255, 0.78);
  background: linear-gradient(145deg, #4b518c 0%, #25295a 100%);
}

.face-outline-toggle-text {
  width: 156rpx;
  height: 66rpx;
  line-height: 66rpx;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.photo-preview {
  position: fixed;
  top: calc(130rpx + env(safe-area-inset-top));
  left: 34rpx;
  right: 34rpx;
  bottom: calc(188rpx + env(safe-area-inset-bottom));
  z-index: 25;
  box-sizing: border-box;
  border: 8rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 42rpx;
  overflow: hidden;
  background: #000000;
  box-shadow: 0 22rpx 54rpx rgba(80, 80, 120, 0.2);
}

.photo {
  width: 100%;
  height: 100%;
}

.bottom-bar {
  position: fixed;
  left: 34rpx;
  right: 34rpx;
  bottom: calc(30rpx + env(safe-area-inset-bottom));
  z-index: 30;
  height: 112rpx;
  padding: 10rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.62);
  box-shadow: 0 18rpx 42rpx rgba(80, 80, 120, 0.14);
  backdrop-filter: blur(20px);
}

.guide-toggle {
  position: relative;
  flex: 1;
  min-width: 0;
  height: 70rpx;
  padding: 5rpx;
  box-sizing: border-box;
  display: flex;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
}

.mode-indicator {
  position: absolute;
  top: 5rpx;
  bottom: 5rpx;
  z-index: 0;
  width: 50%;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #fac3ce 0%, #d7d7ff 100%);
  transition: left 220ms ease;
}

.action-button,
.mode-button {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
  height: 70rpx;
  min-height: 70rpx;
  margin: 0;
  padding: 0 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 30rpx;
  color: #25295a;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: rgba(255, 255, 255, 0.54);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: none;
  box-sizing: border-box;
  white-space: nowrap;
}

.confirm-button {
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  background: linear-gradient(145deg, #4b518c 0%, #25295a 100%);
}

.guide-action-button {
  color: rgba(37, 41, 90, 0.66);
  background: rgba(255, 255, 255, 0.48);
  transition: color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
}

.guide-action-button-active {
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  background: linear-gradient(145deg, #4b518c 0%, #25295a 100%);
  box-shadow: 0 8rpx 18rpx rgba(37, 41, 90, 0.2);
}

.retry-button {
  color: rgba(37, 41, 90, 0.74);
  background: rgba(255, 255, 255, 0.48);
}

.mode-button {
  height: 60rpx;
  min-height: 60rpx;
  color: rgba(37, 41, 90, 0.62);
  background: transparent;
  font-size: 22rpx;
}

.home-return-button {
  flex: none;
  width: 132rpx;
  height: 70rpx;
  min-height: 70rpx;
  color: rgba(37, 41, 90, 0.72);
  background: rgba(255, 255, 255, 0.58);
  font-size: 22rpx;
}

.mode-button-active {
  color: #25295a;
  border: none;
  text-shadow: none;
}

.page-done {
  background: linear-gradient(145deg, #eef0ff 0%, #fff0f5 48%, #e9ecff 100%);
}

.done-page {
  width: 100vw;
  height: 100vh;
  padding: calc(22rpx + env(safe-area-inset-top)) 28rpx calc(22rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  gap: 18rpx;
  background: linear-gradient(145deg, #eef0ff 0%, #fff0f5 48%, #e9ecff 100%);
}

.edit-stage {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 0;
  box-sizing: border-box;
}

.edit-shot {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.edit-image-box {
  flex: none;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 12rpx 30rpx rgba(37, 41, 90, 0.14);
}

.before-edit-box {
  border: 4rpx solid rgba(255, 255, 255, 0.9);
}

.after-edit-box {
  border: 4rpx solid rgba(255, 255, 255, 0.9);
}

.edit-image {
  width: 100%;
  height: 100%;
  transform-origin: center center;
}

.edit-guide {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 2;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.edit-label-wrap {
  position: relative;
  width: 260rpx;
  height: 48rpx;
  line-height: 48rpx;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
}

.edit-label {
  grid-column: 2;
  color: rgba(37, 41, 90, 0.74);
  font-size: 21rpx;
  font-weight: 500;
